# ── Database ──────────────────────────────────────────────────────────────────
# Set USE_TESTCONTAINERS=true to spin up a local PostgreSQL via Docker (default).
# Set POSTGRES_URL to connect to an existing instance instead.
USE_TESTCONTAINERS=true

# Local/external PostgreSQL:
# POSTGRES_URL=jdbc:postgresql://localhost:5432/fagprove
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=

# ── Foreldrepenger søknadskilde ───────────────────────────────────────────────
# Backend syncs Digisis test applications on startup for Testcontainers/external DBs.
# H2/in-memory test startup uses deterministic local seed data unless sync is explicit.
# DIGISIS_SOKNAD_SOURCE_URL=https://api.digisis.org/api/foreldrepenger/soknader
# SYNC_EXTERNAL_SOKNADER=true
# SEED_TEST_SOKNADER=false

# Nais Cloud SQL injects DB_* when envVarPrefix is DB. These are used in staging/prod.
# DB_HOST=
# DB_PORT=5432
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=
# DB_JDBC_URL=

# ── ID-porten (Wonderwall sidecar) ────────────────────────────────────────────
# Leave blank for local dev — authentication is disabled when these are unset.
# Set IDPORTEN_REQUIRED=true only when the backend is exposed behind Wonderwall
# and the frontend forwards user tokens.
# IDPORTEN_ISSUER=https://test.idporten.no
# IDPORTEN_JWKS_URI=https://test.idporten.no/jwks.json
# IDPORTEN_AUDIENCE=your-client-id
# IDPORTEN_REQUIRED=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Defaults to http://localhost:4321.
# ALLOWED_ORIGINS=http://localhost:4321,https://your-app.nav.no

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the frontend SSR server uses to talk to the backend.
# Browser code must call same-origin /api/* routes, not the backend directly.
BACKEND_URL=http://localhost:8080

# Set to "true" to enable MSW (Mock Service Worker) for frontend API mocking.
# PUBLIC_MSW_ENABLED=false

# Decorator environment: "dev" or "prod"
# DECORATOR_ENV=dev
