{
  "name": "fagprove-frontend",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ e2e/ test/ astro.config.mjs eslint.config.mjs playwright.config.ts vitest.config.ts",
    "lint:fix": "eslint src/ e2e/ test/ astro.config.mjs eslint.config.mjs playwright.config.ts vitest.config.ts --fix",
    "format": "prettier --write \"{src,e2e,test}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.config.{js,mjs,ts}\"",
    "format:check": "prettier --check \"{src,e2e,test}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.config.{js,mjs,ts}\""
  },
  "dependencies": {
    "@astrojs/node": "^10.0.5",
    "@astrojs/react": "^5.0.3",
    "@navikt/ds-css": "^8.10.1",
    "@navikt/ds-react": "^8.10.1",
    "@navikt/nav-dekoratoren-moduler": "^3.7.1",
    "astro": "^6.1.8",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}