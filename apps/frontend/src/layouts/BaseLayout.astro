---
import '@navikt/ds-css';
import { AppShell } from '../components/layout/AppShell';
import { MswProvider } from '../components/MswProvider';

const mswEnabled = import.meta.env.PUBLIC_MSW_ENABLED === 'true';

interface Props {
  title: string;
  language?: 'nb' | 'nn' | 'en';
}

const { title, language = 'nb' } = Astro.props;
const pageTitle = title === 'Foreldrepenger' ? title : `${title} - Foreldrepenger`;
---

<html lang={language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Intern saksbehandlerflate for foreldrepenger." />
    <title>{pageTitle}</title>
  </head>
  <body>
    <AppShell>
      <slot />
    </AppShell>
    {mswEnabled && <MswProvider client:only="react" />}
  </body>
</html>
